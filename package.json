{
  "name": "@developmentseed/open-source-contributor-network",
  "version": "2.0.0",
  "description": "Frontend visualization for the Contributor Network",
  "type": "module",
  "files": [
    "dist",
    "public/css",
    "public/img"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-bboxCollide": "^1.0.4",
    "d3-delaunay": "^6.0.4"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/d3-delaunay": "^6.0.4",
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
